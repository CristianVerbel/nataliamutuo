# ── Núcleo ──────────────────────────────────────────────────────────────
ENVIRONMENT=production
PORT=8000
SERVER_URL=                 # URL pública de este servicio (Railway)

# IA
ANTHROPIC_API_KEY=
CLAUDE_MODEL=               # opcional, default en código
OPENAI_API_KEY=             # transcripción (si aplica)
DEEPGRAM_API_KEY=           # voz (si aplica)
GOOGLE_TTS_API_KEY=         # voz (si aplica)

# ── Proveedor de WhatsApp ───────────────────────────────────────────────
WHATSAPP_PROVIDER=whapi     # whapi | meta | twilio | messenger
WHAPI_TOKEN=                # si whapi
META_ACCESS_TOKEN=          # si meta (Cloud API oficial)
META_PHONE_NUMBER_ID=
META_VERIFY_TOKEN=
TWILIO_ACCOUNT_SID=         # si twilio (también SMS)
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Messenger (opcional)
MESSENGER_PAGE_ACCESS_TOKEN=
MESSENGER_PAGE_ID=
MESSENGER_VERIFY_TOKEN=
MESSENGER_PORT=8001

# ── Integración con el sistema principal (mutuoventas) ─────────────────
# Fase actual: acceso directo a Supabase del sistema. Fase 3: gateway API.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
WHATSAPP_BOT_SECRET=        # secreto compartido bot ⇄ edge functions
BOT_INTERNAL_API_KEY=       # auth de la API interna del bot (admin UI)
IMPORT_SECRET=

# Negocio
MERCADOPAGO_ACCESS_TOKEN=
NEQUI_LLAVE_BREB=
NEQUI_QR_URL=
PLAN_IMAGE_BASE_URL=
ADMIN_WHATSAPP=             # número del admin para alertas

# Ajustes
INBOUND_WATCHDOG_MINUTES=30
BOT_PREFS_CACHE_TTL=60
